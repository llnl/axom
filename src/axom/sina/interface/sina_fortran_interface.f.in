!                                            int(merge_protocol, C_INT))
!  end function sina_append_document_to_hdf5

  ! ADD: New wrapper functions for curve ordering
  !function sina_record_set_curve_order(record_handle, curve_order) result(status)
  !  type(C_PTR), intent(in) :: record_handle
  !  integer, intent(in) :: curve_order
  !  integer :: status
  !  
  !  status = sina_record_set_curve_order_c(record_handle, int(curve_order, C_INT))
  !end function sina_record_set_curve_order

  !function sina_record_get_curve_order(record_handle, curve_order) result(status)
