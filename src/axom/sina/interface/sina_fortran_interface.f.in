module sina_functions
  use iso_c_binding  ! ADD THIS LINE - needed for C interop
  implicit none      ! ADD THIS LINE - good practice

  ! MODIFY: Add AUTO_DETECT constant
  integer, parameter :: AUTO_DETECT = -1  ! NEW
  integer, parameter :: JSON = 0
  integer, parameter :: HDF5 = 1
  
  ! ADD: New constants for merge protocols
  integer, parameter :: SINA_MERGE_PROTOCOL_APPEND = 0
  integer, parameter :: SINA_MERGE_PROTOCOL_KEEP_ORIGINAL = 1
  integer, parameter :: SINA_MERGE_PROTOCOL_OVERWRITE = 2
  integer, parameter :: SINA_MERGE_PROTOCOL_ERROR = 3
  
  ! ADD: New constants for curve ordering (PR #1559)
  integer, parameter :: SINA_CURVE_ORDER_REGISTRATION_OLDEST_FIRST = 0
  integer, parameter :: SINA_CURVE_ORDER_REGISTRATION_NEWEST_FIRST = 1
  integer, parameter :: SINA_CURVE_ORDER_ALPHABETICAL = 2
  integer, parameter :: SINA_CURVE_ORDER_REVERSE_ALPHABETICAL = 3

  interface
    
    subroutine create_record(id, recType) 
      character(*) id
      character(*), optional :: recType
    end subroutine create_record
    
  end interface
  
  interface
    subroutine sina_add_file(file_nm, mime_type, rec) 
      character(*) file_nm  
      character(*) mime_type
      character(*), optional ::  rec
    end subroutine sina_add_file
    
  end interface
  
  interface sina_add
  
    subroutine sina_add_long(key, value, units, tags, rec)
      character(*) key
      integer (KIND=8) value
      character(*) units
      character(*) tags
      character(*), optional :: rec
    end subroutine sina_add_long
    
    subroutine sina_add_logical(key, value, units, tags, rec)
      character(*) key
      logical value
      character(*) units
      character(*) tags
      character(*), optional ::  rec
    end subroutine sina_add_logical
    
    subroutine sina_add_int(key, value, units, tags, rec)
      character(*) key
      integer value
      character(*) units
      character(*) tags
      character(*), optional ::  rec
    end subroutine sina_add_int
    
    subroutine sina_add_double(key, value, units, tags, rec)
      character(*) key
      double precision value
      character(*) units
      character(*) tags
      character(*), optional ::  rec
    end subroutine sina_add_double
    subroutine sina_add_float(key, value, units, tags, rec)
      character(*) key
      real value
      character(*) units
      character(*) tags
      character(*), optional ::  rec
    end subroutine sina_add_float
    subroutine sina_add_string(key, value, units, tags, rec)
      character(*) key
      character(*) value
      character(*) units
      character(*) tags
      character(*), optional ::  rec
    end subroutine sina_add_string
    
  end interface
  interface sina_add_curveset
  
    subroutine sina_add_curveset(name, rec)
      character(*) name
      character(*), optional ::  rec
    end subroutine sina_add_curveset
    
  end interface
  
  interface sina_add_curve
  
    subroutine sina_add_curve_double(name, curve, values, n, independent, rec)
      character(*) name
      character(*) curve
      double precision values(n)
      integer n
      logical independent
      character(*), optional ::  rec
    end subroutine sina_add_curve_double
    
    subroutine sina_add_curve_float(name, curve, values, n, independent, rec)
      character(*) name
      character(*) curve
      real values(n)
      integer n
      logical independent
      character(*), optional ::  rec
    end subroutine sina_add_curve_float
    
    subroutine sina_add_curve_int(name, curve, values, n, independent, rec)
      character(*) name
      character(*) curve
      integer (KIND=4), dimension(n) :: values
      integer n
      logical independent
      character(*), optional ::  rec
    end subroutine sina_add_curve_int
    
    subroutine sina_add_curve_long(name, curve, values, n, independent, rec)
      character(*) name
      character(*) curve
      integer (KIND=8), dimension(n) :: values
      integer n
      logical independent
      character(*), optional ::  rec
    end subroutine sina_add_curve_long
    
  end interface
  
  interface write_sina_document
    
    subroutine write_sina_document_all_args(file_nm, protocol, preserve, mergeProtocol) 
      character(*) file_nm  
      integer protocol
      integer mergeProtocol
      integer preserve
    end subroutine write_sina_document_all_args
    
    subroutine write_sina_document_noprotocol_nopreserve_nomerge(file_nm) 
      character(*) file_nm  
    end subroutine write_sina_document_noprotocol_nopreserve_nomerge

    subroutine write_sina_document_protocol_nopreserve_nomerge(file_nm, protocol) 
      character(*) file_nm  
      integer protocol
    end subroutine write_sina_document_protocol_nopreserve_nomerge
    
    subroutine write_sina_document_protocol_preserve_nomerge(file_nm, protocol, preserve) 
      character(*) file_nm  
      integer protocol
      integer preserve
    end subroutine write_sina_document_protocol_preserve_nomerge

  end interface write_sina_document
    
    
!  interface write_sina_document
!    module procedure write_sina_document
!    module procedure save_wi
!  end interface

  ! ADD: New C interface bindings in ONE unnamed interface block
!  interface
