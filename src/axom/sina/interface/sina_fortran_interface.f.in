  ! ADD: New wrapper functions for append
!  function sina_append_document(document_handle, file_path, merge_protocol, output_protocol) result(status)
!    type(C_PTR), intent(in) :: document_handle
!    character(len=*), intent(in) :: file_path
!    integer, intent(in) :: merge_protocol
!    integer, intent(in), optional :: output_protocol
!    integer :: status
    
!    character(len=:, kind=C_CHAR), allocatable :: c_file_path
!    integer(C_INT) :: c_output_protocol
    
!    c_file_path = trim(file_path) // C_NULL_CHAR
    
!    if (present(output_protocol)) then
!      c_output_protocol = int(output_protocol, C_INT)
!    else
!      c_output_protocol = AUTO_DETECT
!    end if
    
!    status = sina_append_document_c(document_handle, c_file_path, &
!                                    int(merge_protocol, C_INT), c_output_protocol)
!  end function sina_append_document

!  function sina_append_document_to_json(document_handle, file_path, merge_protocol) result(status)
!    type(C_PTR), intent(in) :: document_handle
!    character(len=*), intent(in) :: file_path
!    integer, intent(in) :: merge_protocol
!    integer :: status
    
!    character(len=:, kind=C_CHAR), allocatable :: c_file_path
!    c_file_path = trim(file_path) // C_NULL_CHAR
!    status = sina_append_document_to_json_c(document_handle, c_file_path, &
!                                            int(merge_protocol, C_INT))
!  end function sina_append_document_to_json

