module sina_functions
  use iso_c_binding  ! ADD THIS LINE - needed for C interop
  implicit none      ! ADD THIS LINE - good practice

  ! MODIFY: Add AUTO_DETECT constant
  integer, parameter :: AUTO_DETECT = -1  ! NEW
  integer, parameter :: JSON = 0
  integer, parameter :: HDF5 = 1
  
  ! ADD: New constants for merge protocols
  integer, parameter :: SINA_MERGE_PROTOCOL_APPEND = 0
  integer, parameter :: SINA_MERGE_PROTOCOL_KEEP_ORIGINAL = 1
  integer, parameter :: SINA_MERGE_PROTOCOL_OVERWRITE = 2
  integer, parameter :: SINA_MERGE_PROTOCOL_ERROR = 3
  
  ! ADD: New constants for curve ordering (PR #1559)
  integer, parameter :: SINA_CURVE_ORDER_REGISTRATION_OLDEST_FIRST = 0
  integer, parameter :: SINA_CURVE_ORDER_REGISTRATION_NEWEST_FIRST = 1
  integer, parameter :: SINA_CURVE_ORDER_ALPHABETICAL = 2
  integer, parameter :: SINA_CURVE_ORDER_REVERSE_ALPHABETICAL = 3

  interface
    
    subroutine create_document_and_record(id) 
      character(*) id  
    end subroutine create_document_and_record
    
  end interface
  
  interface
    subroutine sina_add_file(file_nm, mime_type) 
      character(*) file_nm  
      character(*) mime_type
    end subroutine sina_add_file
    
  end interface
  
  interface sina_add
  
    subroutine sina_add_long(key, value, units, tags)
      character(*) key
      integer (KIND=8) value
      character(*) units
      character(*) tags
    end subroutine sina_add_long
    
    subroutine sina_add_logical(key, value, units, tags)
      character(*) key
      logical value
      character(*) units
      character(*) tags
    end subroutine sina_add_logical
    
    subroutine sina_add_int(key, value, units, tags)
      character(*) key
      integer value
      character(*) units
      character(*) tags
    end subroutine sina_add_int
    
    subroutine sina_add_double(key, value, units, tags)
      character(*) key
      double precision value
      character(*) units
      character(*) tags
    end subroutine sina_add_double
    subroutine sina_add_float(key, value, units, tags)
      character(*) key
      real value
      character(*) units
      character(*) tags
    end subroutine sina_add_float
    subroutine sina_add_string(key, value, units, tags)
      character(*) key
      character(*) value
      character(*) units
      character(*) tags
    end subroutine sina_add_string
    
  end interface
  interface sina_add_curveset
  
    subroutine sina_add_curveset(name)
      character(*) name
    end subroutine sina_add_curveset
    
  end interface
  
  interface sina_add_curve
  
    subroutine sina_add_curve_double(name, curve, values, n, independent)
      character(*) name
      character(*) curve
      double precision values(n)
      integer n
      logical independent
    end subroutine sina_add_curve_double
    
    subroutine sina_add_curve_float(name, curve, values, n, independent)
      character(*) name
      character(*) curve
      real values(n)
      integer n
      logical independent
    end subroutine sina_add_curve_float
    
    subroutine sina_add_curve_int(name, curve, values, n, independent)
      character(*) name
      character(*) curve
      integer (KIND=4), dimension(n) :: values
      integer n
      logical independent
    end subroutine sina_add_curve_int
    
    subroutine sina_add_curve_long(name, curve, values, n, independent)
      character(*) name
      character(*) curve
      integer (KIND=8), dimension(n) :: values
      integer n
      logical independent
    end subroutine sina_add_curve_long
    
  end interface
  
  interface
    
    subroutine write_sina_document_protocol(file_nm, protocol) 
      character(*) file_nm  
      integer protocol
    end subroutine write_sina_document_protocol
    
  end interface
  interface
    
    subroutine write_sina_document_noprotocol(file_nm) 
      character(*) file_nm  
    end subroutine write_sina_document_noprotocol
    
  end interface
  interface write_sina_document
    module procedure save_with_protocol
    module procedure save_without_protocol
  end interface

  ! ADD: New C interface bindings in ONE unnamed interface block
  interface
    function sina_save_document_c(document_handle, file_path, output_protocol) &
        bind(C, name="sina_save_document_fortran") result(status)
      import :: C_INT, C_PTR, C_CHAR
      integer(C_INT) :: status
      type(C_PTR), value :: document_handle
      character(kind=C_CHAR), dimension(*) :: file_path
      integer(C_INT), value :: output_protocol
    end function sina_save_document_c

    function sina_output_document_to_json_c(document_handle, file_path) &
        bind(C, name="sina_output_document_to_json_fortran") result(status)
      import :: C_INT, C_PTR, C_CHAR
      integer(C_INT) :: status
      type(C_PTR), value :: document_handle
      character(kind=C_CHAR), dimension(*) :: file_path
    end function sina_output_document_to_json_c

    function sina_output_document_to_hdf5_c(document_handle, file_path) &
        bind(C, name="sina_output_document_to_hdf5_fortran") result(status)
      import :: C_INT, C_PTR, C_CHAR
      integer(C_INT) :: status
      type(C_PTR), value :: document_handle
      character(kind=C_CHAR), dimension(*) :: file_path
    end function sina_output_document_to_hdf5_c

    function sina_append_document_c(document_handle, file_path, merge_protocol, output_protocol) &
        bind(C, name="sina_append_document_fortran") result(status)
      import :: C_INT, C_PTR, C_CHAR
      integer(C_INT) :: status
      type(C_PTR), value :: document_handle
      character(kind=C_CHAR), dimension(*) :: file_path
      integer(C_INT), value :: merge_protocol
      integer(C_INT), value :: output_protocol
    end function sina_append_document_c

    function sina_append_document_to_json_c(document_handle, file_path, merge_protocol) &
        bind(C, name="sina_append_document_to_json_fortran") result(status)
      import :: C_INT, C_PTR, C_CHAR
      integer(C_INT) :: status
      type(C_PTR), value :: document_handle
      character(kind=C_CHAR), dimension(*) :: file_path
      integer(C_INT), value :: merge_protocol
    end function sina_append_document_to_json_c

    function sina_append_document_to_hdf5_c(document_handle, file_path, merge_protocol) &
        bind(C, name="sina_append_document_to_hdf5_fortran") result(status)
      import :: C_INT, C_PTR, C_CHAR
      integer(C_INT) :: status
      type(C_PTR), value :: document_handle
      character(kind=C_CHAR), dimension(*) :: file_path
      integer(C_INT), value :: merge_protocol
    end function sina_append_document_to_hdf5_c

!    function sina_record_set_curve_order_c(record_handle, curve_order) &
!        bind(C, name="sina_record_set_curve_order_fortran") result(status)
!      import :: C_INT, C_PTR
!      integer(C_INT) :: status
!      type(C_PTR), value :: record_handle
!      integer(C_INT), value :: curve_order
!    end function sina_record_set_curve_order_c

!    function sina_record_get_curve_order_c(record_handle, curve_order) &
!        bind(C, name="sina_record_get_curve_order_fortran") result(status)
!      import :: C_INT, C_PTR
!      integer(C_INT) :: status
!      type(C_PTR), value :: record_handle
!      integer(C_INT) :: curve_order
!    end function sina_record_get_curve_order_c
  end interface

contains
  subroutine save_with_protocol(fname, proto)
    character(*) fname
    integer proto
    call write_sina_document_protocol(fname, proto)
  end subroutine save_with_protocol
  subroutine save_without_protocol(fname)
    character(*) fname
    call write_sina_document_noprotocol(fname)
  end subroutine save_without_protocol

  ! ADD: New wrapper functions for save/output
  function sina_save_document(document_handle, file_path, output_protocol) result(status)
    type(C_PTR), intent(in) :: document_handle
    character(len=*), intent(in) :: file_path
    integer, intent(in), optional :: output_protocol
    integer :: status
    
    character(len=:, kind=C_CHAR), allocatable :: c_file_path
    integer(C_INT) :: c_output_protocol
    
    c_file_path = trim(file_path) // C_NULL_CHAR
    
    if (present(output_protocol)) then
      c_output_protocol = int(output_protocol, C_INT)
    else
      c_output_protocol = AUTO_DETECT
    end if
    
    status = sina_save_document_c(document_handle, c_file_path, c_output_protocol)
  end function sina_save_document

  function sina_output_document_to_json(document_handle, file_path) result(status)
    type(C_PTR), intent(in) :: document_handle
    character(len=*), intent(in) :: file_path
    integer :: status
    
    character(len=:, kind=C_CHAR), allocatable :: c_file_path
    c_file_path = trim(file_path) // C_NULL_CHAR
    status = sina_output_document_to_json_c(document_handle, c_file_path)
  end function sina_output_document_to_json

  function sina_output_document_to_hdf5(document_handle, file_path) result(status)
    type(C_PTR), intent(in) :: document_handle
    character(len=*), intent(in) :: file_path
    integer :: status
    
    character(len=:, kind=C_CHAR), allocatable :: c_file_path
    c_file_path = trim(file_path) // C_NULL_CHAR
    status = sina_output_document_to_hdf5_c(document_handle, c_file_path)
  end function sina_output_document_to_hdf5

  ! ADD: New wrapper functions for append
  function sina_append_document(document_handle, file_path, merge_protocol, output_protocol) result(status)
    type(C_PTR), intent(in) :: document_handle
    character(len=*), intent(in) :: file_path
    integer, intent(in) :: merge_protocol
    integer, intent(in), optional :: output_protocol
    integer :: status
    
    character(len=:, kind=C_CHAR), allocatable :: c_file_path
    integer(C_INT) :: c_output_protocol
    
    c_file_path = trim(file_path) // C_NULL_CHAR
    
    if (present(output_protocol)) then
      c_output_protocol = int(output_protocol, C_INT)
    else
      c_output_protocol = AUTO_DETECT
    end if
    
    status = sina_append_document_c(document_handle, c_file_path, &
                                    int(merge_protocol, C_INT), c_output_protocol)
  end function sina_append_document

  function sina_append_document_to_json(document_handle, file_path, merge_protocol) result(status)
    type(C_PTR), intent(in) :: document_handle
    character(len=*), intent(in) :: file_path
    integer, intent(in) :: merge_protocol
    integer :: status
    
    character(len=:, kind=C_CHAR), allocatable :: c_file_path
    c_file_path = trim(file_path) // C_NULL_CHAR
    status = sina_append_document_to_json_c(document_handle, c_file_path, &
                                            int(merge_protocol, C_INT))
  end function sina_append_document_to_json

  function sina_append_document_to_hdf5(document_handle, file_path, merge_protocol) result(status)
    type(C_PTR), intent(in) :: document_handle
    character(len=*), intent(in) :: file_path
    integer, intent(in) :: merge_protocol
    integer :: status
    
    character(len=:, kind=C_CHAR), allocatable :: c_file_path
    c_file_path = trim(file_path) // C_NULL_CHAR
    status = sina_append_document_to_hdf5_c(document_handle, c_file_path, &
                                            int(merge_protocol, C_INT))
  end function sina_append_document_to_hdf5

  ! ADD: New wrapper functions for curve ordering
  !function sina_record_set_curve_order(record_handle, curve_order) result(status)
  !  type(C_PTR), intent(in) :: record_handle
  !  integer, intent(in) :: curve_order
  !  integer :: status
  !  
  !  status = sina_record_set_curve_order_c(record_handle, int(curve_order, C_INT))
  !end function sina_record_set_curve_order

  !function sina_record_get_curve_order(record_handle, curve_order) result(status)
  !  type(C_PTR), intent(in) :: record_handle
  !  integer, intent(out) :: curve_order
  !  integer :: status
  !  
  !  integer(C_INT) :: c_curve_order
  !  status = sina_record_get_curve_order_c(record_handle, c_curve_order)
  !  curve_order = int(c_curve_order)
  !end function sina_record_get_curve_order

end module sina_functions
module sina_hdf5_config
  implicit none
  logical, parameter :: use_hdf5 = @AXOM_USE_HDF5_FORTRAN@
end module sina_hdf5_config