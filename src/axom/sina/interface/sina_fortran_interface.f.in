!    function sina_record_get_curve_order_c(record_handle, curve_order) &
!        bind(C, name="sina_record_get_curve_order_fortran") result(status)
!      import :: C_INT, C_PTR
!      integer(C_INT) :: status
!      type(C_PTR), value :: record_handle
!      integer(C_INT) :: curve_order
!    end function sina_record_get_curve_order_c
!  end interface

